# Dependencies (EAS installs on build server)
node_modules/
.yarn

# Website (Next.js) – not needed for Expo app build
website/

# Expo / Metro
.expo/
dist/
web-build/
.metro-health-check*

# Native build artifacts only (keep ios/android source dirs for cloud builds)
*.ipa
*.apk
*.aab
*.app
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
build-*.tar.gz
*.tsbuildinfo

# macOS / local
.DS_Store
*.pem
directusexpo.app
appstore/

# Env (secrets; use EAS Secrets instead)
.env
.env.*
!.env.example

# Debug / misc
npm-debug.*
yarn-debug.*
yarn-error.*

# google-services.json is required for Android (FCM) – keep in project for EAS build; in .gitignore so not committed
