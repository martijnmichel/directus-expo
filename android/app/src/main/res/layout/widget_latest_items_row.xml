<?xml version="1.0" encoding="utf-8"?>
<!-- One list row; host adds N instances via RemoteViews.addView (API 24+).
     Side columns wrap_content; title is the only flex child (weight 1) so it fills space up to the right label.
     Gap between columns via marginEnd on left + title. API 31+ may set exact widths on side FrameLayouts. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_row_item_root"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:paddingTop="0dp"
  android:paddingBottom="0dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:baselineAligned="false">

    <FrameLayout
      android:id="@+id/widget_row_left_container"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginEnd="6dp">

      <ImageView
        android:id="@+id/widget_row_left_image"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/widget_thumb_placeholder"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        android:src="@android:color/transparent"
        android:visibility="gone"
        android:clipToOutline="true"
        android:layout_gravity="center_vertical|start" />

      <TextView
        android:id="@+id/widget_row_left_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="."
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:background="@android:color/transparent"
        android:textColor="#666666"
        android:paddingLeft="0dp"
        android:paddingRight="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:visibility="gone"
        android:gravity="start|center_vertical" />
    </FrameLayout>

    <!-- Title: always flex (weight); widthBehaviour only applies to left/right FrameLayouts. -->
    <TextView
      android:id="@+id/widget_row_title"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:minWidth="0dp"
      android:text=""
      android:textSize="15sp"
      android:textStyle="bold"
      android:maxLines="1"
      android:ellipsize="end"
      android:paddingLeft="0dp"
      android:paddingRight="0dp"
      android:layout_marginEnd="6dp"
      android:gravity="start|center_vertical"
      android:visibility="gone" />

    <FrameLayout
      android:id="@+id/widget_row_right_container"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content">

      <ImageView
        android:id="@+id/widget_row_right_image"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@drawable/widget_thumb_placeholder"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        android:src="@android:color/transparent"
        android:visibility="gone"
        android:clipToOutline="true"
        android:layout_gravity="center_vertical|end" />

      <TextView
        android:id="@+id/widget_row_right_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="."
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:background="@android:color/transparent"
        android:textColor="#666666"
        android:paddingLeft="0dp"
        android:paddingRight="0dp"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:visibility="gone"
        android:gravity="end|center_vertical"
        android:layout_gravity="end|center_vertical" />
    </FrameLayout>

  </LinearLayout>

  <!-- Subtitle: full width; no per-slot layout options. -->
  <TextView
    android:id="@+id/widget_row_subtitle"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text=""
    android:textSize="12sp"
    android:textColor="#666666"
    android:maxLines="1"
    android:ellipsize="end"
    android:paddingLeft="0dp"
    android:paddingRight="0dp"
    android:layout_marginTop="2dp"
    android:visibility="gone" />

  <TextView
    android:id="@+id/widget_row_divider"
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:background="#DDDDDD"
    android:text=""
    android:padding="0dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp" />

</LinearLayout>
