  },
  "build": {
    "simulator": {
        "developmentClient": true,
        "distribution": "internal",
        "env": {
          "ANDROID_SDK_ROOT": "/Volumes/Samsung990PRO/Android/sdk"
        },
        "channel": "development",
        "ios": {
          "simulator": true
        }
      
    },
    "development": {
